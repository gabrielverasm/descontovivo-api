POSTGRES_DB=descontovivo
POSTGRES_USER=descontovivo
POSTGRES_PASSWORD=CHANGE_ME
QUARKUS_HTTP_CORS_ORIGINS=https://yourdomain.com
OIDC_AUTH_SERVER_URL=https://your-keycloak.com/realms/descontovivo
OIDC_CLIENT_ID=descontovivo-api

# Admin Import
ADMIN_IMPORT_TOKEN=CHANGE_ME_GENERATE_STRONG_RANDOM_TOKEN
ADMIN_IMPORT_DEFAULT_AUTHOR=gabrielveras

# Cloudflare R2 Storage
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=descontovivo-promotions
R2_PUBLIC_BASE_URL=https://img.descontovivo.com.br
R2_REGION=auto
IMAGE_MAX_UPLOAD_BYTES=2097152
IMAGE_TARGET_SIZE=300
IMAGE_FORMAT=webp
IMAGE_QUALITY=75
