POSTGRES_DB=descontovivo
POSTGRES_USER=descontovivo
POSTGRES_PASSWORD=descontovivo
QUARKUS_HTTP_CORS_ORIGINS=http://localhost:4200
OIDC_AUTH_SERVER_URL=http://localhost:8082/realms/descontovivo
OIDC_CLIENT_ID=descontovivo-api
# Override issuer claim validation (Docker internal != external URL)
QUARKUS_OIDC_TOKEN_ISSUER=http://localhost:8082/realms/descontovivo

# Admin Import (generate a strong random token for production)
ADMIN_IMPORT_TOKEN=change-me-to-a-secure-random-token
ADMIN_IMPORT_DEFAULT_AUTHOR=gabrielveras

# Cloudflare R2 Storage
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=descontovivo-promotions
R2_PUBLIC_BASE_URL=https://img.descontovivo.com.br
R2_REGION=auto
IMAGE_MAX_UPLOAD_BYTES=2097152
IMAGE_TARGET_SIZE=300
IMAGE_FORMAT=webp
IMAGE_QUALITY=75
